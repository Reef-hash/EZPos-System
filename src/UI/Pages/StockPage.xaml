<UserControl x:Class="EZPos.UI.Pages.StockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:EZPos.UI.Pages"
             Background="{StaticResource ContentBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Summary Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Filter Section -->
            <RowDefinition Height="*"/>
            <!-- Inventory Table -->
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- SUMMARY CARDS SECTION                        -->
        <!-- ============================================ -->
        <Border Grid.Row="0" Padding="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Stock Value Card -->
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" 
                       Padding="16" CornerRadius="6" BorderThickness="1" 
                       BorderBrush="{StaticResource BorderBrush}" Margin="0,0,8,0">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="DollarSign" FontSize="16" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Total Stock Value" Foreground="{StaticResource TextSecondaryBrush}" 
                                      FontSize="11"/>                        </StackPanel>                        <TextBlock Text="RM 8,450.50" Foreground="{StaticResource PrimaryBrush}" 
                                  FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="â†‘ 12% from last month" Foreground="{StaticResource SuccessBrush}" 
                                  FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock Items Card -->
                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" 
                       Padding="16" CornerRadius="6" BorderThickness="1" 
                       BorderBrush="{StaticResource BorderBrush}" Margin="0,0,8,0">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="ExclamationTriangle" FontSize="16" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Low Stock Items" Foreground="{StaticResource TextSecondaryBrush}" 
                                      FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="5 Products" Foreground="{StaticResource WarningBrush}" 
                                  FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Needs reorder soon" Foreground="{StaticResource WarningBrush}" 
                                  FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Out of Stock Card -->
                <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" 
                       Padding="16" CornerRadius="6" BorderThickness="1" 
                       BorderBrush="{StaticResource BorderBrush}" Margin="0,0,8,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="ðŸ”´ Out of Stock" Foreground="{StaticResource TextSecondaryBrush}" 
                                  FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock Text="2 Products" Foreground="{StaticResource ErrorBrush}" 
                                  FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Action required" Foreground="{StaticResource ErrorBrush}" 
                                  FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Units Card -->
                <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" 
                       Padding="16" CornerRadius="6" BorderThickness="1" 
                       BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Cubes" FontSize="16" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Total Units" Foreground="{StaticResource TextSecondaryBrush}" 
                                      FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="1,247" Foreground="{StaticResource InfoBrush}" 
                                  FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Across 47 products" Foreground="{StaticResource InfoBrush}" 
                                  FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- FILTER & ACTION SECTION                      -->
        <!-- ============================================ -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" 
                Padding="16" Margin="0,0,0,12" BorderThickness="0,0,0,1" 
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Filter Options -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Action Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Filter Options -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <Border Width="220" Height="36" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <fa:IconBlock Icon="MagnifyingGlass" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="StockSearchBox" 
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="12"
                                    Text="Search products..."
                                    VerticalAlignment="Center"
                                    TextChanged="SearchBox_TextChanged"/>
                        </StackPanel>
                    </Border>

                    <ComboBox x:Name="StockFilterCombo" 
                             Width="150"
                             Height="32"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Background="{StaticResource SidebarBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="10,6"
                             FontSize="11"
                             SelectionChanged="StockFilterCombo_SelectionChanged"
                             Margin="0,0,12,0">
                        <ComboBoxItem IsSelected="True">All Stock Levels</ComboBoxItem>
                        <ComboBoxItem>In Stock</ComboBoxItem>
                        <ComboBoxItem>Low Stock</ComboBoxItem>
                        <ComboBoxItem>Critical</ComboBoxItem>
                        <ComboBoxItem>Out of Stock</ComboBoxItem>
                    </ComboBox>

                    <ComboBox x:Name="CategoryFilterCombo" 
                             Width="120"
                             Height="32"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Background="{StaticResource SidebarBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="10,6"
                             FontSize="11">
                        <ComboBoxItem IsSelected="True">All Categories</ComboBoxItem>
                        <ComboBoxItem>Beverages</ComboBoxItem>
                        <ComboBoxItem>Snacks</ComboBoxItem>
                        <ComboBoxItem>Baked Goods</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <Button Content="ðŸ“¥ Stock-In" 
                           Style="{StaticResource PrimaryButtonStyle}"
                           Padding="12,6"
                           FontSize="11"
                           Click="StockIn_Click"
                           Margin="0,0,8,0"/>
                    
                    <Button Content="ðŸ“¤ Stock-Out" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="12,6"
                           FontSize="11"
                           Click="StockOut_Click"
                           Margin="0,0,8,0"/>
                    
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                           Padding="12,8"
                           FontSize="11"
                           Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <fa:IconBlock Icon="RotateRight" Margin="0,0,6,0" FontSize="11"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- INVENTORY TABLE                             -->
        <!-- ============================================ -->
        <Border Grid.Row="2">
            <DataGrid x:Name="InventoryGrid" 
                     AutoGenerateColumns="False"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     RowHeight="60">
                <DataGrid.Columns>
                    <!-- Product Name -->
                    <DataGridTextColumn Header="Product Name" 
                                       Binding="{Binding Name}" 
                                       Width="180"
                                       IsReadOnly="True"/>

                    <!-- Barcode -->
                    <DataGridTextColumn Header="Barcode" 
                                       Binding="{Binding Barcode}" 
                                       Width="100"
                                       IsReadOnly="True"/>

                    <!-- Current Stock -->
                    <DataGridTextColumn Header="Current Stock" 
                                       Binding="{Binding Stock}" 
                                       Width="100"
                                       IsReadOnly="True"/>

                    <!-- Stock Level Visualization -->
                    <DataGridTemplateColumn Header="Stock Level" Width="200" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,8,0,8">
                                    <ProgressBar Height="8" Foreground="#FF00D9FF"
                                               Maximum="100" Value="{Binding StockPercentage}" Background="{StaticResource BorderBrush}"/>
                                    <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}" 
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              FontSize="10"
                                              Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Reorder Level -->
                    <DataGridTextColumn Header="Reorder Level" 
                                       Binding="{Binding ReorderLevel}" 
                                       Width="100"
                                       IsReadOnly="True"/>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="Status" Width="90" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,4" CornerRadius="4" 
                                       Background="{Binding Stock, Converter={x:Static local:StockStatusColorConverter.Instance}}">
                                    <TextBlock Text="{Binding Stock, Converter={x:Static local:StockStatusConverter.Instance}}" 
                                              Foreground="White"
                                              FontSize="10" FontWeight="SemiBold"
                                              TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Last Updated -->
                    <DataGridTextColumn Header="Last Updated" 
                                       Binding="{Binding LastUpdated, StringFormat='dd/MM/yyyy'}" 
                                       Width="120"
                                       IsReadOnly="True"/>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="80" CanUserReorder="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0">
                                    <Button Content="Edit" 
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Padding="6,4"
                                           FontSize="9"
                                           Click="EditStock_Click"
                                           Tag="{Binding Id}"
                                           Margin="0,0,4,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
