<UserControl x:Class="EZPos.UI.Pages.StockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:EZPos.UI.Pages"
             Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PosCardStyle}">
            <StackPanel>
                <TextBlock Text="Stock" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Monitor stock levels and reorder risk from a single inventory view." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="In Stock" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="InStockValue" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="24" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Low Stock" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="LowStockValue" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" FontSize="24" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Out of Stock" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="OutOfStockValue" Foreground="{StaticResource ErrorBrush}" FontWeight="Bold" FontSize="24" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource PosCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Total Units" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="TotalUnitsValue" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="24" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PosCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBox x:Name="StockSearchBox"
                             Width="260"
                             Height="36"
                             Margin="0,0,8,8"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged" />

                    <ComboBox x:Name="StockFilterCombo"
                              Width="160"
                              Height="36"
                              Margin="0,0,8,8"
                              SelectionChanged="StockFilterCombo_SelectionChanged">
                        <ComboBoxItem IsSelected="True">All Stock Levels</ComboBoxItem>
                        <ComboBoxItem>In Stock</ComboBoxItem>
                        <ComboBoxItem>Low Stock</ComboBoxItem>
                        <ComboBoxItem>Out of Stock</ComboBoxItem>
                    </ComboBox>

                    <ComboBox x:Name="CategoryFilterCombo"
                              Width="160"
                              Height="36"
                              Margin="0,0,8,8"
                              SelectionChanged="CategoryFilterCombo_SelectionChanged">
                        <!-- Items populated dynamically from CategoryService -->
                    </ComboBox>

                    <Button Style="{StaticResource PrimaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="StockIn_Click">Stock In</Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="StockOut_Click">Stock Out</Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="Refresh_Click">Refresh</Button>
                </WrapPanel>

                <DataGrid x:Name="InventoryGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="1.2*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.2*" />
                        <DataGridTextColumn Header="Current" Binding="{Binding Stock}" Width="0.8*" />
                        <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevel}" Width="0.8*" />

                        <DataGridTemplateColumn Header="Level" Width="1.8*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <ProgressBar Height="7" Maximum="100" Value="{Binding StockPercentage, Mode=OneWay}" Background="{StaticResource BorderBrush}" Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="{Binding StockPercentage, StringFormat='{}{0}%'}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Status" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StockStatus, Converter={x:Static local:StockStatusBrushConverter.Instance}}"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StockStatus}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Updated" Binding="{Binding LastUpdated, StringFormat='{}{0:dd/MM/yyyy}'}" Width="1.1*" />

                        <DataGridTemplateColumn Header="Actions" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Edit"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4"
                                            FontSize="11"
                                            Tag="{Binding}"
                                            Click="EditStock_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
