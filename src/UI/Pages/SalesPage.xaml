<UserControl x:Class="EZPos.UI.Pages.SalesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PosCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sales" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Create transactions and manage active cart items." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="12,8" Click="ClearCart_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="TrashAlt" Margin="0,0,8,0" />
                            <TextBlock Text="Clear Cart" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Click="HoldCurrentTab_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="PauseCircle" Margin="0,0,8,0" />
                            <TextBlock Text="Hold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PosCardStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,12" VerticalAlignment="Top">
                        <TextBox x:Name="ProductSearchBox"
                                 MinWidth="230"
                                 Width="260"
                                 Height="36"
                                 Margin="0,0,8,8"
                                 VerticalContentAlignment="Center"
                                 TextChanged="ProductSearchBox_TextChanged"
                                 KeyDown="ProductSearchBox_KeyDown" />

                        <ComboBox x:Name="CategoryCombo"
                                  Width="170"
                                  Height="36"
                                  Margin="0,0,8,8"
                                  SelectionChanged="CategoryCombo_SelectionChanged">
                            <ComboBoxItem IsSelected="True">All Categories</ComboBoxItem>
                            <ComboBoxItem>Beverages</ComboBoxItem>
                            <ComboBoxItem>Snacks</ComboBoxItem>
                            <ComboBoxItem>Baked Goods</ComboBoxItem>
                        </ComboBox>

                        <Button Width="110"
                                Height="36"
                                Margin="0,0,0,8"
                                Content="Search"
                                Click="SearchButton_Click" />
                    </WrapPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ProductsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="170"
                                            MinHeight="130"
                                            Margin="6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ProductItem_Click">
                                        <StackPanel>
                                            <fa:IconBlock Icon="BoxOpen" FontSize="24" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,8" />
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Barcode}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextAlignment="Center" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Price, StringFormat='RM {0:F2}'}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" TextAlignment="Center" Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PosCardStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Tab strip + cart header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <!-- Scrollable tab strip -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                            <StackPanel x:Name="TabStrip" Orientation="Horizontal" />
                        </ScrollViewer>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Shopping Cart" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="16" />
                            <TextBlock x:Name="CartItemCount" Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CartItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PosListItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding ProductName}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding UnitPrice, StringFormat='RM {0:F2}'}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,5,0,0" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <Button Content="-" Width="34" Height="34" Padding="0" FontSize="16" Tag="{Binding ProductId}" Click="QuantityMinus_Click" />
                                                    <TextBlock Text="{Binding Quantity}" Width="34" TextAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <Button Content="+" Width="34" Height="34" Padding="0" FontSize="16" Tag="{Binding ProductId}" Click="QuantityPlus_Click" />
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Remove"
                                                        Padding="12,8"
                                                        FontSize="13"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Tag="{Binding ProductId}"
                                                        Click="RemoveItem_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="EmptyCartMessage"
                                   Text="Cart is empty"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,10,10,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="CartFooterTotalText" Grid.Column="1" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="20" />
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Padding="14,10" Click="HoldCurrentTab_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconBlock Icon="PauseCircle" Margin="0,0,8,0" />
                                        <TextBlock Text="Hold" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Padding="18,10" Click="Checkout_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <fa:IconBlock Icon="CashRegister" Foreground="{StaticResource SidebarBrush}" Margin="0,0,8,0" />
                                        <TextBlock x:Name="CartFooterCheckoutText" Text="Checkout" Foreground="{StaticResource SidebarBrush}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PosCardStyle}" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Items:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="SummaryItems" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="6,0,20,0" VerticalAlignment="Center" />
                    <TextBlock Text="Subtotal:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="SubtotalText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="6,0,20,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="TaxLabel" Text="Tax:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="TaxText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="6,0,16,0" VerticalAlignment="Center" />
                    <!-- Rounding adjustment — shown only for Cash, hidden otherwise -->
                    <StackPanel x:Name="RoundingRow" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="Rounding:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="RoundingAdjText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="TotalText" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="17" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
