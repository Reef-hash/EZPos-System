<UserControl x:Class="EZPos.UI.ProductsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EZPos.UI"
             Background="{StaticResource ContentBrush}">
    
    <UserControl.Resources>
        <!-- Stock Status Color Indicators -->
        <Style x:Key="StockStatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Products Table -->
            <RowDefinition Height="Auto"/>
            <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- TOOLBAR SECTION                             -->
        <!-- ============================================ -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" 
                Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Search/Filter Area -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Action Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Search and Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <Grid Width="240" Height="36" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <fa:IconBlock Icon="MagnifyingGlass" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox" 
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="12"
                                    Text="Search by name or barcode..."
                                    VerticalAlignment="Center"
                                    TextChanged="SearchBox_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <ComboBox x:Name="FilterCombo" 
                             Width="140"
                             Height="36"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Background="{StaticResource SidebarBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="12,8"
                             FontSize="12"
                             SelectionChanged="FilterCombo_SelectionChanged"
                             Margin="0,0,12,0">
                        <ComboBoxItem>All Products</ComboBoxItem>
                        <ComboBoxItem>In Stock</ComboBoxItem>
                        <ComboBoxItem>Low Stock</ComboBoxItem>
                        <ComboBoxItem>Out of Stock</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Text="{Binding ElementName=ProductsGrid, Path=Items.Count, StringFormat='Total: {0} products'}" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="12,0"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <Button Content="➕ Add Product" 
                           Style="{StaticResource PrimaryButtonStyle}"
                           Padding="12,8"
                           FontSize="11"
                           Click="AddProduct_Click"
                           Margin="0,0,8,0"/>
                    
                    <Button Content="Edit" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="8,4"
                           FontSize="11"
                           Click="EditProduct_Click"
                           Tag="Edit">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <fa:IconBlock Icon="PencilAlt" Margin="0,0,4,0" FontSize="11"/>
                            <TextBlock Text="Edit" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Content="Delete" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="8,4"
                           FontSize="11"
                           Click="DeleteProduct_Click"
                           Foreground="{StaticResource ErrorBrush}"
                           Tag="Delete">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <fa:IconBlock Icon="TrashAlt" Margin="0,0,4,0" FontSize="11" Foreground="{StaticResource ErrorBrush}"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                           Padding="12,8"
                           FontSize="11"
                           Click="RefreshProducts_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <fa:IconBlock Icon="RotateRight" Margin="0,0,6,0" FontSize="11"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- PRODUCTS DATA GRID                          -->
        <!-- ============================================ -->
        <Border Grid.Row="1" Padding="0,12,0,0">
            <DataGrid x:Name="ProductsGrid" 
                     AutoGenerateColumns="False"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     MouseDoubleClick="ProductsGrid_DoubleClick">
                <DataGrid.Columns>
                    <!-- Checkbox Column for Selection -->
                    <DataGridTemplateColumn Header="✓" Width="40" CanUserReorder="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                         HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Barcode Column -->
                    <DataGridTextColumn Header="Barcode" 
                                       Binding="{Binding Barcode}" 
                                       Width="110"
                                       IsReadOnly="True"/>

                    <!-- Product Name Column -->
                    <DataGridTextColumn Header="Product Name" 
                                       Binding="{Binding Name}" 
                                       Width="200"
                                       IsReadOnly="True"/>

                    <!-- Price Column -->
                    <DataGridTextColumn Header="Price (RM)" 
                                       Binding="{Binding Price, StringFormat='N2'}" 
                                       Width="100"
                                       IsReadOnly="True"/>

                    <!-- Stock Column -->
                    <DataGridTextColumn Header="Stock" 
                                       Binding="{Binding Stock}" 
                                       Width="80"
                                       IsReadOnly="True"/>

                    <!-- Status Column -->
                    <DataGridTemplateColumn Header="Status" Width="120" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="4" CornerRadius="4">
                                    <Border.Background>
                                        <Binding Path="Stock" Converter="{x:Static local:StockStatusColorConverter.Instance}" />
                                    </Border.Background>
                                    <TextBlock Text="{Binding Stock, Converter={x:Static local:StockStatusConverter.Instance}}" 
                                              Foreground="White"
                                              Style="{StaticResource StockStatusStyle}"
                                              TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="Actions" Width="100" CanUserReorder="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0">
                                    <Button Content="View" 
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Padding="6,4"
                                           FontSize="10"
                                           Click="ViewProduct_Click"
                                           Tag="{Binding Id}"
                                           Margin="0,0,4,0"/>
                                    <Button Content="Edit" 
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Padding="6,4"
                                           FontSize="10"
                                           Click="EditProduct_Click"
                                           Tag="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ============================================ -->
        <!-- PAGINATION SECTION                          -->
        <!-- ============================================ -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" 
                Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Items Per Page -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Pagination Info -->
                </Grid.ColumnDefinitions>

                <!-- Items Per Page Selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <TextBlock Text="Show:" Foreground="{StaticResource TextSecondaryBrush}" 
                              FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="60" Height="28" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"
                             Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1" Padding="6,4">
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">20</ComboBoxItem>
                        <ComboBoxItem>50</ComboBoxItem>
                        <ComboBoxItem>100</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="per page" Foreground="{StaticResource TextSecondaryBrush}" 
                              FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Pagination Info & Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                    <TextBlock x:Name="PaginationInfo" Text="Page 1 of 5" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    
                    <Button Content="◀ Previous" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="8,4"
                           FontSize="10"
                           Margin="0,0,4,0"/>
                    
                    <Button Content="Next ▶" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Padding="8,4"
                           FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
