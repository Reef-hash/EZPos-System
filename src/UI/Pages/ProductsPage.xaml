<UserControl x:Class="EZPos.UI.Pages.ProductsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:EZPos.UI.Pages"
             Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PosCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Products" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Manage product catalogue and stock readiness." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <TextBlock x:Name="CartCounterText" Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PosCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBox x:Name="SearchBox"
                             Width="280"
                             Height="36"
                             Margin="0,0,8,8"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown" />

                    <ComboBox x:Name="FilterCombo"
                              Width="150"
                              Height="36"
                              Margin="0,0,8,8"
                              SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem IsSelected="True">All Products</ComboBoxItem>
                        <ComboBoxItem>In Stock</ComboBoxItem>
                        <ComboBoxItem>Low Stock</ComboBoxItem>
                        <ComboBoxItem>Out of Stock</ComboBoxItem>
                    </ComboBox>

                    <Button Style="{StaticResource PrimaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="AddProduct_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Plus" Margin="0,0,8,0" Foreground="{StaticResource SidebarBrush}" />
                            <TextBlock Text="Add Product" Foreground="{StaticResource SidebarBrush}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="EditProduct_Click">Edit</Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="DeleteProduct_Click">Delete</Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="ManageCategories_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Tag" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="Categories" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,8" Click="RefreshProducts_Click">Refresh</Button>

                    <TextBlock x:Name="TotalProductsText" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,8" />
                </WrapPanel>

                <DataGrid x:Name="ProductsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          MouseDoubleClick="ProductsGrid_DoubleClick"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="1.4*" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2.4*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.4*" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='RM {0:F2}'}" Width="1*" />
                        <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="0.8*" />

                        <DataGridTemplateColumn Header="Status" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StockStatus, Converter={x:Static local:ProductStatusBrushConverter.Instance}}"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StockStatus}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Actions" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="View"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4"
                                            FontSize="11"
                                            Tag="{Binding}"
                                            Click="ViewProduct_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
