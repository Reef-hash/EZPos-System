<UserControl x:Class="EZPos.UI.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- KPI cards -->
            <RowDefinition Height="Auto" />  <!-- Low stock heading -->
            <RowDefinition Height="*"    />  <!-- Low stock list -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource PosCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Bold" />
                    <TextBlock x:Name="DateLabel"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6" VerticalAlignment="Center" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ArrowsRotate" FontSize="12" Margin="0,0,6,0" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── KPI Cards ── -->
        <Border Grid.Row="1" Padding="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Today's Revenue -->
                <Border Grid.Column="0" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="DollarSign" FontSize="14"
                                          Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="Today's Revenue" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock x:Name="TodayRevenueText" Text="RM 0.00"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- Today's Transactions -->
                <Border Grid.Column="1" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Receipt" FontSize="14"
                                          Foreground="{StaticResource InfoBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="Transactions Today" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock x:Name="TodayOrdersText" Text="0"
                                   Foreground="{StaticResource InfoBrush}"
                                   FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- Low Stock Count -->
                <Border Grid.Column="2" Style="{StaticResource PosCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="TriangleExclamation" FontSize="14"
                                          Foreground="{StaticResource WarningBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="Low Stock Items" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock x:Name="LowStockCountText" Text="0"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- Avg Order Value -->
                <Border Grid.Column="3" Style="{StaticResource PosCardStyle}" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="ArrowTrendUp" FontSize="14"
                                          Foreground="{StaticResource SuccessBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="Avg Order Value" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock x:Name="AvgOrderText" Text="RM 0.00"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Low Stock Heading ── -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0"
                CornerRadius="6,6,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <fa:IconBlock Icon="TriangleExclamation" FontSize="14"
                              Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0"
                              VerticalAlignment="Center" />
                <TextBlock Text="Low Stock Alerts"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="LowStockSubLabel"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Low Stock List ── -->
        <Border Grid.Row="3" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6" Padding="0">
            <DataGrid x:Name="LowStockGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product"       Binding="{Binding Name}"         Width="*" />
                    <DataGridTextColumn Header="Current Stock" Binding="{Binding Stock}"         Width="140" />
                    <DataGridTextColumn Header="Reorder Level" Binding="{Binding ReorderLevel}"  Width="140" />
                    <DataGridTemplateColumn Header="Status" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left"
                                        Background="{StaticResource WarningBrush}">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Low Stock" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Stock}" Value="0">
                                                        <Setter Property="Text" Value="Out of Stock" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Empty state overlay -->
        <Border Grid.Row="3" x:Name="EmptyAlertPanel" Visibility="Collapsed"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                <fa:IconBlock Icon="CircleCheck" FontSize="36"
                              Foreground="{StaticResource SuccessBrush}"
                              HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Text="All stock levels are healthy!"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
