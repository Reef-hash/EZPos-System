<Window x:Class="EZPos.UI.Dialogs.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" WindowStartupLocation="CenterOwner" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="500" SizeToContent="Height" ShowInTaskbar="False">

    <!-- Dark overlay background -->
    <Border Background="#1A1A1A" CornerRadius="12" Padding="20">
        <StackPanel Orientation="Vertical">

            <!-- Header -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                <TextBlock Text="Update Available" FontSize="20" FontWeight="Bold" Foreground="White" />
                <Rectangle Height="1" Fill="#00D9FF" Width="40" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Version info -->
            <Border Background="#2A2A2A" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Current Version" FontSize="12" Foreground="#AAAAAA" />
                        <TextBlock x:Name="CurrentVersionLabel" Text="1.0.0" FontSize="16" Foreground="White" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                        <TextBlock Text="Available Version" FontSize="12" Foreground="#AAAAAA" />
                        <TextBlock x:Name="AvailableVersionLabel" Text="1.0.1" FontSize="16" Foreground="#00D9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Mandatory warning (hidden by default) -->
            <Border x:Name="MandatoryWarning" Background="#4A2A2A" Padding="12" CornerRadius="6" Visibility="Collapsed" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="20" Foreground="#FF6B6B" Margin="0,0,12,0" />
                    <TextBlock Text="This update is mandatory. Your current version is no longer supported." 
                               Foreground="#FF9999" TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Release Notes -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                <TextBlock Text="What's New" FontSize="14" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,6" />
                <Border Background="#2A2A2A" CornerRadius="6">
                    <ScrollViewer Height="150" Padding="12" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesTextBlock" Text="Loading release notes..." 
                                   Foreground="#CCCCCC" TextWrapping="Wrap" LineHeight="18" />
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button x:Name="SkipButton" Content="Skip for Now" Width="120" Height="40" Margin="0,0,10,0"
                        Background="#3A3A3A" Foreground="White" 
                        FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                        Click="SkipButton_Click"
                        Style="{DynamicResource {x:Type Button}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="UpdateButton" Content="Update Now" Width="120" Height="40" 
                        Background="#00D9FF" Foreground="#1A1A1A" 
                        FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                        Click="UpdateButton_Click"
                        Style="{DynamicResource {x:Type Button}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Footer note -->
            <TextBlock Text="The app will restart to complete the update. Make sure you finish any active sales." 
                       FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,16,0,0" />

        </StackPanel>
    </Border>

</Window>
