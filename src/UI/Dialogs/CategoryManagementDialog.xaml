<Window x:Class="EZPos.UI.Dialogs.CategoryManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Manage Categories"
        Width="460" Height="520"
        MinWidth="400" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{StaticResource ContentBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="0" CaptionHeight="0"
                      GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- title bar -->
                <RowDefinition Height="*"    />   <!-- content -->
                <RowDefinition Height="Auto" />   <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Grid Grid.Row="0" Background="{StaticResource SidebarBrush}"
                  Height="44" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <fa:IconBlock Icon="Tag" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="Manage Categories"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Style="{StaticResource WinCloseButtonStyle}"
                        Width="44" Height="44"
                        HorizontalAlignment="Right"
                        ToolTip="Close"
                        Click="CloseBtn_Click">
                    <fa:IconBlock Icon="Xmark" FontSize="14" />
                </Button>
            </Grid>

            <!-- ── Content ── -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- add row -->
                    <RowDefinition Height="*"    />  <!-- list -->
                    <RowDefinition Height="Auto" />  <!-- action row -->
                </Grid.RowDefinitions>

                <!-- Add new category -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewCategoryBox"
                             Grid.Column="0" Height="36"
                             VerticalContentAlignment="Center"
                             FontSize="13"
                             KeyDown="NewCategoryBox_KeyDown"
                             Tag="Category name…">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Category name…"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13" Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="14,0"
                            FontSize="13"
                            Click="AddBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Plus" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="Add" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Error / status message -->
                <TextBlock x:Name="StatusText"
                           Grid.Row="0"
                           VerticalAlignment="Bottom"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11" Margin="0,0,0,-12"
                           Visibility="Collapsed" />

                <!-- Category list -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Margin="0,18,0,0">
                    <ListBox x:Name="CategoryList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="13"
                             SelectionMode="Single"
                             SelectionChanged="CategoryList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="#0F172A" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <!-- Action buttons for selected item -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RenameBtn"
                            Grid.Column="0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" IsEnabled="False"
                            Click="RenameBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="PencilAlt" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="Rename Selected" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="DeleteBtn"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" IsEnabled="False"
                            Foreground="{StaticResource ErrorBrush}"
                            Click="DeleteBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="TrashAlt" FontSize="12" Margin="0,0,6,0"
                                         Foreground="{StaticResource ErrorBrush}" />
                            <TextBlock Text="Delete Selected" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ── Footer ── -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <TextBlock x:Name="FooterText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Text="Select a category to rename or delete. 'General' cannot be deleted." />
            </Border>
        </Grid>
    </Border>
</Window>
