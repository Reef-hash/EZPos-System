<Window x:Class="EZPos.UI.Dialogs.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Category"
        Width="360" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{StaticResource ContentBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="0" CaptionHeight="0"
                      GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
        <StackPanel Margin="20,16">
            <TextBlock x:Name="PromptText"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,8" />
            <TextBox x:Name="NameBox"
                     Height="36" FontSize="13"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,14"
                     KeyDown="NameBox_KeyDown" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34" Padding="16,0" Margin="0,0,8,0"
                        Click="CancelBtn_Click" />
                <Button Content="Rename"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="34" Padding="16,0"
                        Click="OkBtn_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
