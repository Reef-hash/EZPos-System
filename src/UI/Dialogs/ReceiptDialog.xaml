<Window x:Class="EZPos.UI.Dialogs.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Receipt"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ContentBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid x:Name="ReceiptContentPanel" Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Sale info -->
            <RowDefinition Height="Auto" /> <!-- Divider -->
            <RowDefinition Height="Auto" /> <!-- Line items -->
            <RowDefinition Height="Auto" /> <!-- Divider -->
            <RowDefinition Height="Auto" /> <!-- Totals -->
            <RowDefinition Height="Auto" /> <!-- Payment -->
            <RowDefinition Height="Auto" /> <!-- Close button -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
            <fa:IconBlock Icon="Receipt" FontSize="32"
                          Foreground="{StaticResource PrimaryBrush}"
                          HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Transaction Complete"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock x:Name="SaleIdText" Text="#0000"
                       Foreground="{StaticResource PrimaryBrush}"
                       FontSize="13" HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock x:Name="DateTimeText" Text=""
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>

        <!-- ── Divider ── -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12" />

        <!-- ── Line items ── -->
        <ItemsControl Grid.Row="2" x:Name="LineItemsControl" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ProductName}"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Quantity, StringFormat='x{0}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" Margin="8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding LineTotal, StringFormat='RM {0:F2}'}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" HorizontalAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Divider ── -->
        <Border Grid.Row="3" Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12" />

        <!-- ── Totals ── -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <Grid Margin="0,3">
                <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                <TextBlock x:Name="SubtotalText" Text="RM 0.00"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" HorizontalAlignment="Right" />
            </Grid>
            <Grid Margin="0,3">
                <TextBlock x:Name="TaxLabel" Text="Tax" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                <TextBlock x:Name="TaxText" Text="RM 0.00"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" HorizontalAlignment="Right" />
            </Grid>
            <!-- Rounding adjustment row — hidden when zero -->
            <Grid x:Name="RoundingRow" Margin="0,3" Visibility="Collapsed">
                <TextBlock Text="Rounding" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                <TextBlock x:Name="RoundingAdjText" Text="+RM 0.00"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" HorizontalAlignment="Right" />
            </Grid>
            <Grid Margin="0,6,0,0">
                <TextBlock Text="TOTAL" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock x:Name="TotalText" Text="RM 0.00"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" />
            </Grid>
        </StackPanel>

        <!-- ── Payment ── -->
        <Border Grid.Row="5" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="Payment Method" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="PaymentMethodText" Text="Cash"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <TextBlock Text="Tendered" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    <TextBlock x:Name="TenderedText" Text="RM 0.00"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="2">
                    <TextBlock Text="Change" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock x:Name="ChangeText" Text="RM 0.00"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" />
                </Grid>
            </Grid>
        </Border>

        <!-- ── Close ── -->
        <Grid Grid.Row="6" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="PrintBtn" Grid.Column="0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Print Receipt" Height="40"
                    Click="Print_Click" />
            <Button x:Name="NewSaleBtn" Grid.Column="2"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="New Sale" Height="40"
                    Click="Close_Click" />
        </Grid>
    </Grid>
</Window>
