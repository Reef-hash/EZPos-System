<Window x:Class="EZPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EZPos.UI"
        Title="EZPos" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <!-- Logo/Name -->
                <StackPanel Orientation="Horizontal" Height="80" VerticalAlignment="Top" Margin="0,20,0,20">
                    <Ellipse Width="40" Height="40" Fill="{StaticResource AccentBrush}" Margin="20,0,10,0"/>
                    <TextBlock Text="EZPos"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>
                <!-- Navigation Buttons -->
                <StackPanel>
                    <Button x:Name="SalesNavBtn" Content="Sales" Style="{StaticResource {x:Type Button}}" Margin="10,4" Click="NavButton_Click"/>
                    <Button x:Name="ProductsNavBtn" Content="Products" Style="{StaticResource {x:Type Button}}" Margin="10,4" Click="NavButton_Click"/>
                    <Button x:Name="StockNavBtn" Content="Stock" Style="{StaticResource {x:Type Button}}" Margin="10,4" Click="NavButton_Click"/>
                    <Button x:Name="ReportsNavBtn" Content="Reports" Style="{StaticResource {x:Type Button}}" Margin="10,4" Click="NavButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="{StaticResource ContentBrush}">
            <ContentControl x:Name="MainContent" />
        </Border>
    </Grid>
</Window>
