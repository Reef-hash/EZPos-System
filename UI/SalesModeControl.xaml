<!-- WPF replacement for SalesModeControl.cs -->
<UserControl x:Class="EZPos.UI.SalesModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="txtBarcode" Grid.Row="0" Height="32" Margin="0,0,0,10" FontSize="16" PlaceholderText="Imbas kod bar..."/>
        <DataGrid x:Name="dgvCart" Grid.Row="1" Margin="0,0,0,10" AutoGenerateColumns="False" Height="200">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="*"/>
                <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Kuantiti" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="Harga" Binding="{Binding Price}" Width="*"/>
                <DataGridTextColumn Header="Jumlah" Binding="{Binding Total}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="lblTotal" Grid.Row="2" FontSize="16" FontWeight="Bold" Text="Jumlah: RM0.00" Margin="0,10,0,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Tunai:" VerticalAlignment="Center" FontSize="14" Width="60"/>
            <TextBox x:Name="txtCash" Width="120" Height="28" FontSize="14" Margin="5,0,0,0"/>
            <TextBlock x:Name="lblChange" Text="Baki: RM0.00" VerticalAlignment="Center" FontSize="14" Margin="20,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,20,0,0">
            <Button x:Name="btnPay" Content="BAYAR" Width="120" Height="40" Margin="0,0,10,0" Background="{StaticResource AccentBrush}" Foreground="White"/>
            <Button x:Name="btnClear" Content="CLEAR" Width="120" Height="40" Background="#FFB71C1C" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>
