<Window x:Class="EZPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="EZPos"
        Icon="/Resources/Icons/app.ico"
        MinHeight="700"
        MinWidth="1100"
        Height="800"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource SidebarBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="5" CaptionHeight="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══ Custom Title Bar ══ -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource SidebarBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <!-- App branding (left) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="/Resources/Icons/app.ico" Width="42" Height="42" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="EZPos" FontFamily="{StaticResource AppFont}" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text=" — Point of Sale" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
            </StackPanel>

            <!-- Window controls (right) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeBtn" Width="46" Height="52"
                        Click="MinimizeBtn_Click"
                        ToolTip="Minimize"
                        Style="{StaticResource WinCtrlButtonStyle}" >
                    <fa:IconBlock Icon="Minus" FontSize="14" />
                </Button>
                <Button x:Name="MaximizeBtn" Width="46" Height="52"
                        Click="MaximizeBtn_Click"
                        ToolTip="Maximize"
                        Style="{StaticResource WinCtrlButtonStyle}">
                    <fa:IconBlock x:Name="MaximizeIcon" Icon="Expand" FontSize="14" />
                </Button>
                <Button x:Name="CloseBtn" Width="46" Height="52"
                        Click="CloseBtn_Click"
                        ToolTip="Close"
                        Style="{StaticResource WinCloseButtonStyle}">
                    <fa:IconBlock Icon="Xmark" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Sidebar ══ -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="14,10,14,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12" />

                <StackPanel Grid.Row="1">
                    <Button x:Name="DashboardNavBtn" Style="{StaticResource NavButtonStyle}" Content="Dashboard" Tag="Dashboard" Click="NavButton_Click" />
                    <Button x:Name="SalesNavBtn" Style="{StaticResource NavButtonStyle}" Content="Sales" Tag="Sales" Click="NavButton_Click" />
                    <Button x:Name="ProductsNavBtn" Style="{StaticResource NavButtonStyle}" Content="Products" Tag="Products" Click="NavButton_Click" />
                    <Button x:Name="StockNavBtn" Style="{StaticResource NavButtonStyle}" Content="Stock" Tag="Stock" Click="NavButton_Click" />
                    <Button x:Name="ReportsNavBtn" Style="{StaticResource NavButtonStyle}" Content="Reports" Tag="Reports" Click="NavButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <Button x:Name="SettingsNavBtn" Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="12,8" Margin="0,0,0,8" Click="SettingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Cog" Margin="0,0,8,0" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="12,8" Click="AboutButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CircleInfo" Margin="0,0,8,0" />
                            <TextBlock Text="About" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource ContentBrush}" Padding="14">
            <Border Style="{StaticResource PosCardStyle}" Padding="12" Margin="0" BorderThickness="0">
                <ContentControl x:Name="MainContent" />
            </Border>
        </Border>
    </Grid>
</Window>
