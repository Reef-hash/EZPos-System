<Window x:Class="EZPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="EZPos"
        Icon="/Resources/Icons/app.ico"
        MinHeight="700"
        MinWidth="1100"
        Height="800"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="14,18,14,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                        <Viewbox Width="20" Height="20">
                            <fa:IconBlock Icon="CashRegister" Foreground="{StaticResource SidebarBrush}" />
                        </Viewbox>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="EZPos" FontFamily="{StaticResource AppFont}" FontWeight="Bold" FontSize="19" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Point of Sale" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12" />

                <StackPanel Grid.Row="2">
                    <Button x:Name="DashboardNavBtn" Style="{StaticResource NavButtonStyle}" Content="Dashboard" Tag="Dashboard" Click="NavButton_Click" />
                    <Button x:Name="SalesNavBtn" Style="{StaticResource NavButtonStyle}" Content="Sales" Tag="Sales" Click="NavButton_Click" />
                    <Button x:Name="ProductsNavBtn" Style="{StaticResource NavButtonStyle}" Content="Products" Tag="Products" Click="NavButton_Click" />
                    <Button x:Name="StockNavBtn" Style="{StaticResource NavButtonStyle}" Content="Stock" Tag="Stock" Click="NavButton_Click" />
                    <Button x:Name="ReportsNavBtn" Style="{StaticResource NavButtonStyle}" Content="Reports" Tag="Reports" Click="NavButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <Button x:Name="SettingsNavBtn" Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="12,8" Margin="0,0,0,8" Click="SettingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Cog" Margin="0,0,8,0" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="12,8" Click="AboutButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CircleInfo" Margin="0,0,8,0" />
                            <TextBlock Text="About" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource ContentBrush}" Padding="14">
            <Border Style="{StaticResource PosCardStyle}" Padding="12" Margin="0" BorderThickness="0">
                <ContentControl x:Name="MainContent" />
            </Border>
        </Border>
    </Grid>
</Window>
